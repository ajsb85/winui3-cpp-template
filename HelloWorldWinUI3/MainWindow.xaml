<?xml version="1.0" encoding="utf-8"?>
<!--
    MainWindow.xaml  (v2 — Mica + Custom Title Bar)
    ────────────────────────────────────────────────
    New in this version
    • <Window.SystemBackdrop> declares MicaBackdrop Kind="Base" directly in XAML.
      No code-behind controller is needed; the SDK handles Win10 fallback automatically.
    • Root Grid background is Transparent so Mica shows through everywhere.
    • Row 0 (32 px) hosts a custom title bar (AppTitleBar) with a FontIcon glyph and
      a TextBlock whose Foreground is bound to {ThemeResource ApplicationForegroundThemeBrush}
      so colours flip between light / dark mode automatically.
    • Row 1 contains the existing card.  The card background uses
      CardBackgroundFillColorDefaultBrush — a WinUI 3 token correct in both themes.
    • ExtendsContentIntoTitleBar and SetTitleBar are called in code-behind (C++ only API).
    • AppWindowTitleBar button colours are set transparently in code-behind so the
      native Min/Max/Close buttons blend with Mica.
-->
<Window
    x:Class="HelloWorldWinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HelloWorldWinUI3"
    Title="Hello World — WinUI 3">

    <!-- ── Step 1: Declare Mica Base material in XAML (simplest approach) ─── -->
    <!--
        MicaBackdrop is available from Windows App SDK 1.3 onwards.
        On older hosts (Windows 10, battery-saver mode, transparency disabled) the
        SDK automatically falls back to a solid-colour surface — no extra code needed.
        Use Kind="BaseAlt" instead for tabbed-style apps (e.g. File Explorer style).
    -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <!--
        ── Step 2: Root Grid — must be Transparent so Mica is fully visible ──
        Two rows:
          Row 0 — custom title bar   (32 px, matches standard Win11 title bar height)
          Row 1 — application content
    -->
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 0 — Custom title bar
             x:Name="AppTitleBar" is used by SetTitleBar() in code-behind
             to register it as the draggable / system-menu region.
             Background must be Transparent for Mica to show here too.
             ════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- icon  -->
                <ColumnDefinition Width="Auto"/> <!-- title -->
                <ColumnDefinition Width="*"/>    <!-- drag region (fill) -->
            </Grid.ColumnDefinitions>

            <!--
                App icon — Segoe Fluent Icons glyph E80F (globe / world icon).
                {ThemeResource ApplicationForegroundThemeBrush} automatically
                switches between #000000 (light mode) and #FFFFFF (dark mode)
                at runtime without any C++ code.
            -->
            <FontIcon
                Grid.Column="0"
                Glyph="&#xE80F;"
                FontSize="14"
                Margin="16,0,8,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>

            <!--
                App title text — CaptionTextBlockStyle gives the correct
                weight / size for a Win11 title bar caption.
            -->
            <TextBlock
                Grid.Column="1"
                Text="Hello World — WinUI 3"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>

            <!--
                Column 2 is intentionally empty — it acts as the primary
                drag region.  The native Min/Max/Close buttons are drawn by
                Windows on top of this area; no extra XAML is needed.
            -->
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 1 — NavigationView host for pages
             ════════════════════════════════════════════════════════════════ -->
        <NavigationView
            x:Name="MainNavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsSettingsVisible="True"
            ItemInvoked="MainNavView_ItemInvoked"
            Loaded="MainNavView_Loaded"
            Background="Transparent">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="Home"/>
            </NavigationView.MenuItems>

            <!-- Main frame that loads Pages inside NavigationView content area -->
            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
