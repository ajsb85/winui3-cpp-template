<Page
    x:Class="HelloWorldWinUI3.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HelloWorldWinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Background="Transparent">
        <!-- ── Glassmorphism content card ── -->
        <Border
            x:Name="ContentCard"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="20"
            Padding="56,48"
            MinWidth="400">

            <!-- Gradient accent border (purple → blue) -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#2563EB" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>1.5</Border.BorderThickness>

            <StackPanel Orientation="Vertical" Spacing="28">

                <!-- ── App icon badge (gradient pill) ── -->
                <Border
                    Width="64" Height="64"
                    CornerRadius="16"
                    HorizontalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock
                        Text="&#xE80F;"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="28"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <!-- ── Main greeting — theme-aware foreground ── -->
                <TextBlock
                    x:Name="GreetingTextBlock"
                    Text="Hello, World!"
                    FontSize="36"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>

                <!-- ── Subtitle ── -->
                <TextBlock
                    x:Name="SubtitleTextBlock"
                    Text="Built with WinUI 3 · Windows App SDK · C++/WinRT"
                    FontSize="13"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Opacity="0.55"
                    Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>

                <!-- ── Hairline divider ── -->
                <Rectangle
                    Height="1"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Opacity="0.4"/>

                <!-- ── Primary CTA — gradient button ── -->
                <Button
                    x:Name="MyButton"
                    Content="Procesar Información (Async)"
                    Click="MyButton_Click"
                    HorizontalAlignment="Center"
                    MinWidth="220"
                    Padding="24,12"
                    CornerRadius="10"
                    FontSize="15"
                    FontWeight="SemiBold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>
