<?xml version="1.0" encoding="utf-8"?>
<!--
    App.xaml
    Defines global application resources and sets the start-up window.
-->
<Application
    x:Class="HelloWorldWinUI3.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    WinUI 3 provides a rich set of default styles.
                    XamlControlsResources pulls in the complete control theme.
                -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
